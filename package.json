{
  "name": "devdomain",
  "version": "1.1.5",
  "description": "Give your dev server a clean .test domain with zero config. Works with Vite, Next.js, Nuxt, and any dev server.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "devdomain": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite-plugin/index.js",
      "types": "./dist/vite-plugin/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "devdomain",
    "dev-server",
    "local-domain",
    "local-development",
    "test-domain",
    "dottest",
    "vite-plugin",
    "vite",
    "nextjs",
    "nuxt",
    "proxy",
    "reverse-proxy",
    "https",
    "ssl",
    "mkcert",
    "hosts",
    "localhost",
    "domain",
    "dns",
    "herd",
    "valet",
    "laravel-herd",
    "laravel-valet"
  ],
  "homepage": "https://github.com/lysari/devdomain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lysari/devdomain.git"
  },
  "bugs": {
    "url": "https://github.com/lysari/devdomain/issues"
  },
  "author": "Sari Ly",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "http-proxy": "^1.18.1",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.14",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
